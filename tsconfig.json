{
  "compilerOptions": {
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "downlevelIteration": true,
    "target": "ES2024",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": [
        "./src/*"
      ],
      "@public/*": [
        "./public/*"
      ],
      "@subtrees/*": [
        "./subtrees/*"
      ]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    "next.config.ts",
    "src/app/api/protected/loc/[id]/config/tax/[taxId]/stripe",
    ".archived/StripeTax.tsx",
    ".archived/StripeReg.tsx",
    ".archived/StripeTaxSettings.tsx",
    "src/app/dashboard/location/[id]/settings/tax/components/schema.ts",
    "subtrees/schemas",
    "subtrees/types",
    ".next/dev/types/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "subtrees/emails"
  ]
}
